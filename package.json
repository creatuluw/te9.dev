{
  "name": "te9.dev-v2",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node build/index.js",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:setup": "node scripts/setup-db.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sync:raindrop": "node scripts/sync-raindrop.js",
    "sync:crawl": "node scripts/crawl-bookmarks.js",
    "sync:analyze": "node scripts/analyze-bookmarks.js",
    "digest:setup": "node scripts/setup-digests-db.js",
    "digest:last10": "node scripts/generate-digest.js --type last10",
    "digest:last10:send": "node scripts/generate-digest.js --type last10 --send",
    "digest:weekly": "node scripts/generate-digest.js --type weekly",
    "digest:weekly:send": "node scripts/generate-digest.js --type weekly --send"
  },
  "devDependencies": {
    "@mozilla/readability": "^0.6.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^29.0.2",
    "postgres": "^3.4.9",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "turndown": "^7.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.1",
    "vitest-browser-svelte": "^2.1.0"
  },
  "dependencies": {
    "@lucide/svelte": "^1.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "emailjs": "^5.0.0",
    "zod": "^4.3.6"
  }
}
